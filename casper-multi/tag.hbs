{{!< default}}
{{!-- The tag above means - insert everything in this file into the {body} of the default.hbs template --}}

<main id="site-main" class="site-main outer">
<div class="inner posts">
    <div class="post-feed">

        {{#tag}}
        <section class="post-card post-card-large">

            {{#if feature_image}}
            <div class="post-card-image-link">
                {{!-- This is a responsive image, it loads different sizes depending on device
                https://medium.freecodecamp.org/a-guide-to-responsive-images-with-ready-to-use-templates-c400bd65c433 --}}
                <img class="post-card-image"
                    srcset="{{img_url feature_image size="s"}} 300w,
                            {{img_url feature_image size="m"}} 600w,
                            {{img_url feature_image size="l"}} 1000w,
                            {{img_url feature_image size="xl"}} 2000w"
                    sizes="(max-width: 1000px) 400px, 800px"
                    src="{{img_url feature_image size="m"}}"
                    alt="{{title}}"
                />
            </div>
            {{/if}}

            <div class="post-card-content">
            <div class="post-card-content-link">
                <header class="post-card-header">
                    <h2 class="post-card-title">{{name}}</h2>
                </header>
                <div class="post-card-excerpt">
                    {{#if description}}
                        {{description}}
                    {{else}}
                        A collection of {{plural ../pagination.total empty='zero posts' singular='% post' plural='% posts'}}
                    {{/if}}
                </div>
            </div>
            </div>

        </section>
        {{/tag}}

        {{#foreach posts}}
            <div class="post-card" data-tags='[{{#foreach tags visibility="all"}}"{{name}}"{{#unless @last}},{{/unless}}{{/foreach}}]'>
                {{!-- The tag below includes the markup for each post - partials/post-card.hbs --}}
                {{> "post-card"}}
            </div>
        {{/foreach}}
    </div>

    {{pagination}}
    <style>
        .post-card-excerpt,
        div.post-card {
            opacity: 0; /* Initially set all post cards to be transparent */
            transition: opacity 0.5s ease; /* Transition for smooth display */
        }
    </style>

    <script type="text/javascript" src="{{asset 'js/util.js'}}"></script>
    <script>
    document.addEventListener('DOMContentLoaded', function() {
        const LANGS = ["en", "ko"];                       // supported languages; extend here
        const selectedLanguage = getSelectedLanguage();   // from localStorage, default 'en'
        const postCards = document.querySelectorAll('div.post-card[data-tags]');
        let visibleCount = 0;

        postCards.forEach(card => {
            // Parse all tag names for this post, find the language tag regardless of position
            let tagNames = [];
            try {
                tagNames = JSON.parse(card.getAttribute('data-tags') || '[]');
            } catch (e) {}

            let cardLang = null;
            LANGS.forEach(l => {
                if (tagNames.indexOf('#' + l) !== -1) cardLang = l;
            });

            // Hide cards whose language doesn't match the selected one (or have no language tag)
            if (cardLang !== selectedLanguage) {
                card.style.display = 'none';
            } else {
                visibleCount++;
                setTimeout(() => {  // smooth reveal
                    card.style.opacity = 1;
                    const excerpts = card.querySelectorAll('.post-card-excerpt');
                    excerpts.forEach(excerpt => {
                        excerpt.style.opacity = 1;
                    });
                }, 10);
            }
        });

        // Dynamically update text
        const collectionText = document.querySelector('.post-card-excerpt');
        if (collectionText) {
            const text = visibleCount === 0 ? 'zero posts' :
                        visibleCount === 1 ? '1 post' :
                        `${visibleCount} posts`;  // Set text based on the count
            collectionText.innerHTML = `A collection of ${text}`;  // Set text in HTML
            setTimeout(() => {  // Use setTimeout for a smooth display
                collectionText.style.opacity = 1;  // Set opacity to 1 to make the element visible
            }, 10);
        }
    });
    </script>
    
</div>
</main>